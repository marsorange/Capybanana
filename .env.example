# Copy to .env.local and fill in. Postcard image generation (MiniMax / 海螺).
# Get a key from https://platform.minimaxi.com . Without it, postcards fall
# back to the built-in procedural SVG art.
MINIMAX_API_KEY=

# Optional overrides (defaults shown):
# MINIMAX_IMAGE_URL=https://api.minimaxi.com/v1/image_generation
# MINIMAX_IMAGE_MODEL=image-01

# --- Accounts + agent connect (cloud save) ---
# Hosted KV for accounts / bind tokens / pet saves. On Vercel, add a
# Storage → "Upstash for Redis" database and it injects these automatically.
# Either naming works (Upstash native or Vercel KV). Leave blank locally to use
# an in-memory fallback (data is not persisted across restarts).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Optional: pin the public origin used in the agent bind link. If unset, it is
# derived from the request (the deployed domain on Vercel).
# APP_BASE_URL=https://your-app.vercel.app
