# --- Login (Supabase Auth, default) ---
# The owner signs in with Google through Supabase Auth; the app then mints its
# own bind token. Both values are public (safe to expose to the browser).
#   1. Create a Supabase project → Project Settings → API: copy the URL + anon key.
#   2. Authentication → Providers → enable Google (paste a Google OAuth client
#      id/secret from Google Cloud Console).
#   3. Authentication → URL Configuration → add your site + redirect URLs
#      (http://localhost:3000 for dev, plus your deployed origin).
# Without these, the login screen shows "登录暂不可用".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Local debug login (optional, no Supabase) ---
# For localhost debugging when you don't have Supabase access, enable BOTH flags:
# the server route switch + the client login button switch.
# CAPY_DEV_LOCAL_AUTH=1
# NEXT_PUBLIC_CAPY_DEV_LOCAL_AUTH=1

# --- Accounts + agent connect (SQL cloud save) ---
# All gameplay data is stored in PostgreSQL, usually Supabase Postgres. Run the
# SQL migration in supabase/migrations before using cloud save.
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
# Local PostgreSQL example:
# POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/capybanana

# Optional: pin the public origin used in the agent bind link. If unset, it is
# derived from the request (the deployed domain on Vercel).
# APP_BASE_URL=https://your-app.vercel.app

# --- Camera recognition (MiniMax / 海螺 Token Plan VLM) ---
# Optional. Used only to name photographed suitcase items. Without a key, camera
# packing falls back to color-based heuristics.
MINIMAX_API_KEY=
# Optional override:
# MINIMAX_VLM_URL=https://api.minimaxi.com/v1/coding_plan/vlm
