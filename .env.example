# --- Login (Supabase Auth, default) ---
# The owner signs in with Google through Supabase Auth; the app then mints its
# own bind token. Both values are public (safe to expose to the browser).
#   1. Create a Supabase project → Project Settings → API: copy the URL + anon key.
#   2. Authentication → Providers → enable Google (paste a Google OAuth client
#      id/secret from Google Cloud Console).
#   3. Authentication → URL Configuration → add your site + redirect URLs
#      (http://localhost:3000 for dev, plus your deployed origin).
# Without these, the login screen shows "登录暂不可用".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Local debug login (optional, no Supabase) ---
# For localhost debugging when you don't have Supabase access, enable BOTH flags:
# the server route switch + the client login button switch.
# CAPY_DEV_LOCAL_AUTH=1
# NEXT_PUBLIC_CAPY_DEV_LOCAL_AUTH=1

# --- Accounts + agent connect (cloud save) ---
# Hosted store for accounts / bind tokens / pet saves. Pick ONE; on Vercel the
# matching Storage integration injects these env vars automatically. Leave all
# blank locally to use an in-memory fallback (not persisted; dev only).
#
# Option A — Redis (Upstash / Vercel KV). Either naming works.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
#
# Option B — Postgres (e.g. Supabase). The app creates its own tiny tables
# (capy_kv, capy_kv_set) on first use, so no manual SQL is needed. The pooled
# URL (port 6543) is preferred for serverless.
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
# Local PostgreSQL example:
# POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/capybanana

# Optional: pin the public origin used in the agent bind link. If unset, it is
# derived from the request (the deployed domain on Vercel).
# APP_BASE_URL=https://your-app.vercel.app

# --- Postcard AI art (MiniMax / 海螺 image-01) ---
# Generates the postcard image (pet + famous-landmark scenery) on demand,
# server-side, cached. Without a key, postcards fall back to procedural SVG art.
# Get a key from https://platform.minimaxi.com .
MINIMAX_API_KEY=
# Optional overrides (defaults shown):
# MINIMAX_IMAGE_URL=https://api.minimaxi.com/v1/image_generation
# MINIMAX_IMAGE_MODEL=image-01
